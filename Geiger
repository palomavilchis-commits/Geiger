import serial
import time
import csv

# Crea el archivo
with open('Geiger_SensorData.csv', mode='a', newline='') as sensor_file:
    sensor_writer = csv.writer(sensor_file, delimiter=',', quotechar='"', quoting=csv.QUOTE_MINIMAL)
    sensor_writer.writerow(["Counts", "CPM", "Tiempo"])  # nombre de columnas


com = "/dev/cu.usbmodem14101 o COM4"
baud = 9600
LOG_PERIOD = 60  # Debe coincidir con LOG_PERIOD del Arduino (en segundos)

x = serial.Serial(com, baud, timeout=0.1)
while x.isOpen():
    data = x.readline().decode('utf-8').strip()
    if data != '':
        try:

            if data.isdigit():
                counts = int(data)
                cpm = round((counts / LOG_PERIOD) * 60, 2)

                print(f"Counts: {counts}, CPM: {cpm}")

        
                with open('Geiger_SensorData.csv', mode='a', newline='') as sensor_file:
                    sensor_writer = csv.writer(sensor_file, delimiter=',', quotechar='"', quoting=csv.QUOTE_MINIMAL)
                    sensor_writer.writerow([counts, cpm, time.strftime("%H:%M:%S")])  # hora:minuto:segundo

        except (ValueError, IndexError) as e:
            print(f"Could not parse Geiger data: {data} ({e})")
